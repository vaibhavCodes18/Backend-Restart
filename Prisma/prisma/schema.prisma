generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id      Int      @id @default(autoincrement())
  email   String   @unique
  name    String?
  orders  Order[]
}

model Product {
  id      Int      @id @default(autoincrement())
  name    String
  price   Float
  orders  Order[]
}

model Order {
  id        Int       @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int

  user      User      @relation(fields: [userId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}
